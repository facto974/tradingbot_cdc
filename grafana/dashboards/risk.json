{
  "title": "CryptoComMCP - Risk & Latency",
  "uid": "gmcp-risk",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Max Drawdown",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "gmcp_max_drawdown_pct", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Win rate",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "gmcp_win_rate", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Trades total",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "gmcp_trades_total", "refId": "A"}]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Loop p95 (s)",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(gmcp_loop_duration_seconds_bucket[5m])) by (le))", "refId": "A"}]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "API latency (CryptoCom)",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.5, sum(rate(gmcp_api_latency_seconds_bucket[5m])) by (le, endpoint))", "legendFormat": "p50 {{endpoint}}", "refId": "A"}, {"expr": "histogram_quantile(0.95, sum(rate(gmcp_api_latency_seconds_bucket[5m])) by (le, endpoint))", "legendFormat": "p95 {{endpoint}}", "refId": "B"}]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Errors / min",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "rate(gmcp_errors_total[1m])", "legendFormat": "{{component}}", "refId": "A"}]
    }
  ]
}
