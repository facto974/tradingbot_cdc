{
  "title": "CryptoComMCP - Trading PnL & Equity",
  "uid": "gmcp-trading",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-24h", "to": "now"},
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Equity (USD)",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "gmcp_equity_usd", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "color": {"mode": "thresholds"}}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Realized PnL",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "gmcp_realized_pnl_usd", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Unrealized PnL",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "gmcp_unrealized_pnl_usd", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Open Positions",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "gmcp_open_positions", "refId": "A"}]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Equity Curve",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "gmcp_equity_usd", "refId": "A"}]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Price by Symbol",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "gmcp_price_usd", "legendFormat": "{{symbol}}", "refId": "A"}]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Strategy Score",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "targets": [{"expr": "gmcp_strategy_score", "legendFormat": "{{symbol}}", "refId": "A"}]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Orders / min",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "targets": [{"expr": "rate(gmcp_orders_total[1m])", "legendFormat": "{{side}}", "refId": "A"}]
    }
  ]
}
